{
  "name": "discord-custom-presence",
  "version": "0.1.2",
  "description": "Cross-platform desktop app to manage a custom Discord Rich Presence.",
  "main": "src/main.js",
  "author": {
    "name": "Yannis Piot Pilot",
    "email": "yannis@piotpilot.eu"
  },
  "license": "MIT",
  "private": false,
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "extension:zip": "node scripts/package-extension.js",
    "lint": "eslint ."
  },
  "dependencies": {
    "discord-rpc": "^4.0.1"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "eslint": "^9.15.0"
  },
  "build": {
    "appId": "com.example.discordcustompresence",
    "productName": "Discord Custom Presence",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "browser-extension/**/*",
      "README.md",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}
